---
import { asset } from '../utils/asset';
import TitleWithUnderline from './TitleWithUnderline.astro';

const baseWaveHeights = [
  12, 24, 40, 32, 25, 10, 26, 21, 24, 23, 26, 40,
  31, 25, 25, 11, 26, 21, 24, 10, 27, 21, 25, 21, 24,
];
const waveHeights = [...baseWaveHeights, ...baseWaveHeights, ...baseWaveHeights.slice(0, 8)];
---

<div class="radio-section">
  <TitleWithUnderline
    variant="flourish"
    align="left"
    size="compact"
    underlineWidth={11}
    underlineThickness={1.35}
    class="radio-section__title"
  >
    Spot radiowy
    <img
      slot="trailing"
      class="radio-section__fm-icon"
      src={asset('/assets/radio-fm-icon.png')}
      alt=""
      width="56"
      height="53"
      aria-hidden="true"
    />
  </TitleWithUnderline>
  <p class="radio-section__sub">Posłuchaj spotu kampanii</p>
  <div class="audio-player" role="group" aria-label="Odtwarzacz audio">
    <audio
      class="audio-player__audio"
      preload="metadata"
      src={asset('/assets/spot-radiowy.wav')}
    ></audio>
    <button class="audio-player__play" aria-label="Odtwórz spot" type="button">
      <img
        class="btn__icon btn__icon--play"
        src={asset("/assets/icon-play.svg")}
        alt=""
        aria-hidden="true"
      />
      <span class="audio-player__pause" aria-hidden="true">
        <span></span>
        <span></span>
      </span>
    </button>
    <div class="audio-player__wave" aria-hidden="true">
      {waveHeights.map((height) => (
        <span style={`height: ${height}px`}></span>
      ))}
    </div>
    <button class="audio-player__stop" type="button" aria-label="Zatrzymaj odsłuch">■</button>
    <span class="audio-player__time" aria-live="polite">0:00 / 0:00</span>
  </div>
</div>

<script is:inline>
  (() => {
    const scriptEl = document.currentScript;
    const root = scriptEl?.previousElementSibling?.classList.contains('radio-section')
      ? scriptEl.previousElementSibling
      : null;
    if (!root) return;

    const audio = root.querySelector('.audio-player__audio');
    const playButton = root.querySelector('.audio-player__play');
    const stopButton = root.querySelector('.audio-player__stop');
    const timeLabel = root.querySelector('.audio-player__time');

    if (!audio || !playButton || !stopButton || !timeLabel) return;

    const formatTime = (seconds) => {
      if (!Number.isFinite(seconds) || seconds < 0) return '0:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60)
        .toString()
        .padStart(2, '0');
      return `${mins}:${secs}`;
    };

    const updateTime = () => {
      timeLabel.textContent = `${formatTime(audio.currentTime)} / ${formatTime(audio.duration)}`;
    };

    const setPlayingState = (isPlaying) => {
      playButton.classList.toggle('is-playing', isPlaying);
      playButton.setAttribute('aria-label', isPlaying ? 'Pauza spotu' : 'Odtwórz spot');
    };

    const showLoadError = () => {
      setPlayingState(false);
      timeLabel.textContent = 'Brak pliku audio';
    };

    playButton.addEventListener('click', async () => {
      if (audio.paused) {
        try {
          await audio.play();
          setPlayingState(true);
        } catch {
          showLoadError();
        }
      } else {
        audio.pause();
        setPlayingState(false);
      }
    });

    stopButton.addEventListener('click', () => {
      audio.pause();
      audio.currentTime = 0;
      setPlayingState(false);
      updateTime();
    });

    audio.addEventListener('loadedmetadata', updateTime);
    audio.addEventListener('error', showLoadError);
    audio.addEventListener('timeupdate', updateTime);
    audio.addEventListener('ended', () => {
      audio.currentTime = 0;
      setPlayingState(false);
      updateTime();
    });

    updateTime();
  })();
</script>

<style>
  .radio-section {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    height: 100%;
    padding: var(--media-card-padding-block) var(--media-card-padding-inline);
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 24px;
    background: #fdecf0;
    border: 2px solid #e2d0d9;
    border-radius: 15px;
  }

  .radio-section__title {
    flex-shrink: 0;
    min-width: 0;
  }

  .radio-section__fm-icon {
    flex-shrink: 0;
    width: clamp(44px, 8vw, 56px);
    height: auto;
    margin-left: 10px;
    transform-origin: 50% 90%;
    transition: transform 0.2s ease;
  }

  .radio-section__fm-icon:hover {
    animation: radio-section-fm-sway 1.2s ease-in-out infinite;
  }

  @keyframes radio-section-fm-sway {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-8deg); }
    75% { transform: rotate(8deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .radio-section__fm-icon:hover {
      animation: none;
    }
  }

  .radio-section__sub {
    font-size: 2rem;
    font-weight: 400;
    font-family: 'Barlow Condensed', sans-serif;
    color: #1a1a1a;
    margin-top: -12px;
  }

  .audio-player {
    grid-row: 4;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    background: #d7316e;
    border-radius: 39px;
    padding: 0 12px;
    height: var(--media-control-height);
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    box-sizing: border-box;
  }

  .audio-player__audio {
    display: none;
  }

  .audio-player__play {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 6px 0 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    align-self: center;
  }

  .audio-player__play .btn__icon--play {
    height: 44px;
    border: none;
  }

  .audio-player__pause {
    display: none;
    align-items: center;
    gap: 6px;
    height: 30px;
  }

  .audio-player__pause span {
    width: 5px;
    height: 30px;
    border-radius: 999px;
    background: #fff;
  }

  .audio-player__play.is-playing .btn__icon--play {
    display: none;
  }

  .audio-player__play.is-playing .audio-player__pause {
    display: inline-flex;
  }

  .audio-player__wave {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2px;
    align-self: stretch;
    height: 100%;
    overflow: hidden;
  }

  .audio-player__wave span {
    display: block;
    width: 2px;
    background: #fff;
    border-radius: 1px;
    opacity: 0.9;
    flex-shrink: 0;
    align-self: center;
  }

  .audio-player__time {
    display: flex;
    align-items: center;
    font-size: 16px;
    font-weight: 700;
    line-height: 1;
    color: #fff;
    white-space: nowrap;
    flex-shrink: 0;
    align-self: center;
  }

  .audio-player__stop {
    border: none;
    background: transparent;
    color: #fff;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    padding: 6px;
    flex-shrink: 0;
  }

  /* Narrow two-column layout (radio card beside posters) */
  @media (min-width: 901px) and (max-width: 1100px) {
    .radio-section {
      gap: 16px;
      --media-card-padding-inline: 24px;
    }

    .radio-section__sub {
      font-size: 1.5rem;
      margin-top: -8px;
    }

    .audio-player {
      height: 56px;
      padding: 0 8px;
      gap: 5px;
      border-radius: 28px;
    }

    .audio-player__play {
      padding: 0 4px 0 10px;
    }

    .audio-player__play .btn__icon--play {
      height: 32px;
    }

    .audio-player__pause {
      height: 22px;
      gap: 5px;
    }

    .audio-player__pause span {
      width: 4px;
      height: 22px;
    }

    .audio-player__wave {
      overflow: hidden;
      gap: 1px;
    }

    .audio-player__wave span {
      width: 1.5px;
    }

    .audio-player__time {
      font-size: 12px;
    }

    .audio-player__stop {
      font-size: 14px;
      padding: 2px;
    }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .radio-section {
      gap: 16px;
    }

    .radio-section__title :global(.title-with-underline__decoration) {
      width: var(--underline-width, 11rem);
      max-width: 100%;
    }

    .radio-section__fm-icon {
      width: 54px;
    }

    .radio-section__sub {
      font-size: 1.5rem;
      margin-top: -8px;
    }

    .audio-player {
      width: 100%;
      max-width: 100%;
      justify-self: stretch;
      padding: 0 8px;
      gap: 5px;
      height: 56px;
      border-radius: 28px;
    }

    .audio-player__play {
      padding: 0 4px 0 10px;
    }

    .audio-player__play .btn__icon--play {
      height: 32px;
    }

    .audio-player__pause {
      height: 22px;
      gap: 5px;
    }

    .audio-player__pause span {
      width: 4px;
      height: 22px;
    }

    .audio-player__wave {
      overflow: hidden;
      justify-content: space-between;
      gap: 1px;
    }

    .audio-player__wave span {
      width: 1.5px;
    }

    .audio-player__time {
      font-size: 12px;
    }

    .audio-player__stop {
      font-size: 14px;
      padding: 2px;
    }
  }

  @media (max-width: 640px) {
    .radio-section {
      gap: 14px;
    }

    .radio-section__title :global(.title-with-underline__decoration) {
      width: var(--underline-width, 11rem);
      max-width: 100%;
    }

    .radio-section__fm-icon {
      width: 50px;
    }

    .radio-section__sub {
      font-size: 1.25rem;
      margin-top: -6px;
    }

    .audio-player {
      height: 48px;
      padding: 0 8px;
      gap: 4px;
      border-radius: 24px;
    }

    .audio-player__play {
      padding: 0 4px 0 8px;
    }

    .audio-player__play .btn__icon--play {
      height: 28px;
    }

    .audio-player__pause {
      height: 18px;
      gap: 4px;
    }

    .audio-player__pause span {
      width: 3px;
      height: 18px;
    }

    .audio-player__wave {
      justify-content: space-between;
      gap: 1px;
    }

    .audio-player__wave span {
      width: 1.5px;
    }

    .audio-player__time {
      font-size: 11px;
    }

    .audio-player__stop {
      font-size: 13px;
      padding: 2px;
    }
  }
</style>
