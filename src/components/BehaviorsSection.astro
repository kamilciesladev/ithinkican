---
import { asset } from '../utils/asset';
import TitleWithUnderline from './TitleWithUnderline.astro';
---

<section id="uwazac" class="section-behaviors">
  <div class="section-behaviors__card">
    <svg class="behaviors-card-border" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <rect
        fill="none"
        stroke="#f5bdab"
        stroke-width="2"
        stroke-dasharray="12 22"
        vector-effect="non-scaling-stroke"
        width="100%"
        height="100%"
        rx="12"
        ry="12"
      />
    </svg>
    <div class="behaviors-heading">
      <TitleWithUnderline
        variant="flourish"
        align="center"
      underlineWidth={20}
      underlineThickness={1}
    >
        Jakie zachowania<br />są nieakceptowalne?
      </TitleWithUnderline>
    </div>
    <div class="behaviors-content">
      <ul class="behaviors-list">
        <li class="behaviors-list__item">
          <img
            class="behaviors-list__icon"
            src={asset("/assets/exclamation-bullet.svg")}
            alt=""
            aria-hidden="true"
          />
          <p>
            <strong>Przemoc i dręczenie psychiczne</strong> – obejmuje bicie, popychanie,
            szarpanie, groźby, wyzwiska i upokarzanie, ciągłe krytykowanie oraz stosowanie
            „cichego traktowania" jako formy kary lub manipulacji.
          </p>
        </li>
        <li class="behaviors-list__item">
          <img
            class="behaviors-list__icon"
            src={asset("/assets/exclamation-bullet.svg")}
            alt=""
            aria-hidden="true"
          />
          <p>
            <strong>Brak szacunku do granic</strong> – ignorowanie „nie", wywieranie presji
            oraz stosowanie szantażu emocjonalnego („jeśli mnie kochasz, to…").
          </p>
        </li>
        <li class="behaviors-list__item">
          <img
            class="behaviors-list__icon"
            src={asset("/assets/exclamation-bullet.svg")}
            alt=""
            aria-hidden="true"
          />
          <p>
            <strong>Zaniedbywanie dzieci</strong> – brak opieki i zaangażowania w wychowanie,
            ignorowanie potrzeb emocjonalnych i fizycznych dziecka, unikanie obowiązków
            rodzicielskich, brak wsparcia i bezpieczeństwa, a także narażanie dziecka
            na doświadczenie przemocy.
          </p>
        </li>
      </ul>
      <p class="behaviors-helpline">
        Jeśli potrzebujesz pomocy lub doświadczasz przemocy, możesz skontaktować się
        z <b>„Niebieską Linią"</b> – <strong> telefon 800 120 002</strong> (bezpłatnie, anonimowo).
        W nagłych sytuacjach dzwoń na <strong>112</strong>.
      </p>
    </div>
    <div class="behaviors-photo">
      <img src={asset("/assets/behaviors-illustration.png")} alt="Ilustracja zachowań nieakceptowalnych" />
    </div>
  </div>
</section>

<style>
  .section-behaviors {
    padding: 60px var(--section-inset-x) 56px;
  }

  .section-behaviors__card {
    position: relative;
    background: #fff7ef;
    border-radius: 12px;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(220px, 30vw, 380px);
    column-gap: clamp(12px, 2vw, 28px);
    align-items: end;
    padding: 40px clamp(24px, 3vw, 40px) 40px clamp(24px, 4vw, 60px);
  }

  .behaviors-heading {
    grid-column: 1 / -1;
    margin-bottom: 8px;
  }

  .behaviors-card-border {
    position: absolute;
    inset: 1px;
    width: calc(100% - 2px);
    height: calc(100% - 2px);
    pointer-events: none;
    overflow: visible;
  }

  .behaviors-content {
    min-width: 0;
    position: relative;
    z-index: 1;
  }

  .behaviors-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .behaviors-list__item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .behaviors-list__icon {
    flex-shrink: 0;
    width: 16px;
    height: auto;
    margin-top: 0;
  }

  .behaviors-list__item p {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.6;
    font-family: 'Barlow Condensed', sans-serif;
  }

  .behaviors-list__item strong { font-weight: 700; }

  .behaviors-photo {
    position: relative;
    width: 100%;
    max-width: clamp(220px, 30vw, 380px);
    justify-self: end;
    align-self: end;
    margin-right: -12px;
    margin-bottom: -24px;
    z-index: 1;
    pointer-events: none;
  }

  .behaviors-photo img {
    display: block;
    width: 100%;
    height: auto;
  }

  .behaviors-helpline {
    margin-top: clamp(24px, 4vw, 40px);
    font-size: 17px;
    font-weight: 400;
    font-family: 'Barlow Condensed', sans-serif;
    color: #444;
    line-height: 1.5;
    max-width: none;
  }

  .behaviors-helpline strong { font-weight: 700; color: #1a1a1a; }

  @media (max-width: 900px) {
    .section-behaviors {
      padding: 48px var(--section-inset-x) 44px;
    }

    .section-behaviors__card {
      grid-template-columns: 1fr;
      row-gap: 20px;
      padding: 32px 24px;
    }

    .behaviors-heading {
      margin-bottom: 4px;
    }

    .behaviors-photo {
      justify-self: center;
      max-width: min(360px, 80vw);
      margin-right: 0;
      margin-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .behaviors-photo {
      display: none;
    }

    .behaviors-list {
      gap: 24px;
    }

    .behaviors-list__item {
      gap: 14px;
    }

    .behaviors-list__item p {
      font-size: 16px;
      line-height: 1.5;
    }

    .behaviors-helpline {
      font-size: 16px;
      line-height: 1.45;
    }
  }
</style>
