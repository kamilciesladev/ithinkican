---
import { asset } from '../utils/asset';
import SocialLinks from "./SocialLinks.astro";
---

<header class="header">
  <a href="#top" class="header__logo-link" aria-label="Powrót na górę strony">
    <img
      class="header__logo"
      src={asset("/assets/header-logo.png")}
      alt="On Da Radę — logo"
      width="96"
      height="63"
    />
  </a>
  <nav class="header__nav" aria-label="Nawigacja główna">
    <a href="#kampanii">O kampanii</a>
    <a href="#uwazac">Na co uważać</a>
    <a href="#przyklady">Dobre przykłady</a>
    <a href="#materialy">Materiały</a>
    <a href="#zrodla">Źródła</a>
  </nav>
  <div class="header__social">
    <SocialLinks />
  </div>
</header>

<style>
  .header {
    display: grid;
    grid-template-columns: 96px 1fr auto;
    align-items: center;
    width: 100%;
    min-height: 140px;
    padding: 26px 64px;
    column-gap: 53px;
  }

  .header__logo-link {
    display: block;
    grid-column: 1;
    line-height: 0;
    transition: opacity 0.2s;
  }

  .header__logo-link:hover {
    opacity: 0.65;
  }

  .header__logo {
    width: 96px;
    height: auto;
    object-fit: contain;
  }

  .header__nav {
    grid-column: 2;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-start;
    column-gap: 40px;
    row-gap: 8px;
    min-width: 0;
  }

  .header__nav a {
    font-size: 1.25rem;
    letter-spacing: 1.2px;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .header__nav a:hover {
    opacity: 0.65;
  }

  .header__social {
    grid-column: 3;
    justify-self: end;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .header {
      grid-template-columns: auto 1fr;
      padding: 20px 24px;
      min-height: auto;
      column-gap: 16px;
    }

    .header__nav {
      display: none;
    }

    .header__social {
      grid-column: 2;
    }

    .header__logo {
      width: 72px;
    }
  }
</style>
