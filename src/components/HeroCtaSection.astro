---
import { asset } from '../utils/asset';

const heroImage = asset('/assets/hero.png');
---

<section
  class="hero"
  role="img"
  aria-label="On Da Radę — kampania społeczna"
  style={`background-image: url('${heroImage}')`}
>
  <div class="hero__buttons">
    <a href="#materialy" class="btn btn--pink">
      <img class="btn__icon btn__icon--document" src={asset("/assets/icon-document.svg")} alt="" aria-hidden="true" />
      ZOBACZ ULOTKĘ
    </a>
    <a href="#spoty" class="btn btn--blue">
      <img class="btn__icon btn__icon--play" src={asset("/assets/icon-play.svg")} alt="" aria-hidden="true" />
      OBEJRZYJ SPOTY
    </a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 1024 / 564;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .hero__buttons {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(8px, 2vw, 80px);
    padding: 0 clamp(16px, 2.5vw, 32px) clamp(12px, 4.5vw, 28px);
    z-index: 1;
  }

  .hero__buttons .btn {
    height: clamp(52px, 6.56vw, 84px);
    font-size: clamp(16px, 2.19vw, 28px);
    letter-spacing: 0.05em;
    padding: 0 clamp(16px, 2.5vw, 32px);
    border-radius: clamp(24px, 3.05vw, 39px);
    gap: clamp(10px, 1.25vw, 16px);
  }

  .hero__buttons .btn--pink { width: clamp(200px, 22.81vw, 292px); }
  .hero__buttons .btn--blue { width: clamp(210px, 24.38vw, 312px); }

  .hero__buttons .btn__icon {
    display: block;
    flex-shrink: 0;
    width: auto;
    object-fit: contain;
  }

  .hero__buttons .btn__icon--document {
    height: clamp(26px, 3vw, 38px);
  }

  .hero__buttons .btn__icon--play {
    height: clamp(30px, 3.6vw, 44px);
    border: none;
  }

  @media (max-width: 900px) {
    .hero__buttons {
      gap: 8px;
      padding-bottom: clamp(10px, 3vw, 18px);
    }

    .hero__buttons .btn {
      flex: 0 0 auto;
      width: fit-content;
      height: 48px;
      font-size: clamp(13px, 2vw, 18px);
      padding: 0 16px;
      border-radius: 24px;
      gap: 8px;
    }

    .hero__buttons .btn--pink,
    .hero__buttons .btn--blue {
      width: fit-content;
      max-width: none;
    }

    .hero__buttons .btn__icon--document { height: 20px; }
    .hero__buttons .btn__icon--play { height: 24px; }
  }

  @media (max-width: 640px) {
    .hero__buttons {
      gap: 8px;
      padding-left: var(--section-inset-x);
      padding-right: var(--section-inset-x);
      padding-bottom: 12px;
    }

    .hero__buttons .btn {
      height: 40px;
      font-size: 12px;
      padding: 0 12px;
      border-radius: 20px;
      gap: 6px;
    }

    .hero__buttons .btn__icon--document { height: 18px; }
    .hero__buttons .btn__icon--play { height: 20px; }
  }
</style>
