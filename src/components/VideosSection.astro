---
import { asset } from '../utils/asset';
import TitleWithUnderline from './TitleWithUnderline.astro';

const youtubeVideoId = 'jr9Z6Bsbisk';
const youtubeEmbedUrl = `https://www.youtube.com/embed/${youtubeVideoId}`;
const youtubeChannelUrl = 'https://www.youtube.com/';
---

<section id="spoty" class="section-videos">
  <div class="section-videos__header">
    <TitleWithUnderline
      variant="flourish"
      align="left"
      size="compact"
      underlineWidth={11}
      underlineThickness={1.35}
      class="section-videos__title"
    >
      Spot video
      <img
        slot="trailing"
        class="section-videos__paw"
        src={asset('/assets/spot-paw.svg')}
        alt=""
        width="72"
        height="51"
        aria-hidden="true"
      />
    </TitleWithUnderline>
    <a
      href={youtubeChannelUrl}
      class="btn btn--blue btn--yt"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        class="btn__icon btn__icon--play"
        src={asset("/assets/icon-play.svg")}
        alt=""
        aria-hidden="true"
      />
      OBEJRZYJ SPOT NA YOUTUBE
    </a>
  </div>

  <div class="section-videos__player">
    <iframe
      class="section-videos__iframe"
      src={youtubeEmbedUrl}
      title="Spot wideo"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
</section>

<style>
  .section-videos {
    background: #fff;
    padding: 54px var(--section-inset-x) 64px;
  }

  .section-videos__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .section-videos__title {
    flex-shrink: 1;
    min-width: 0;
  }

  .section-videos__paw {
    flex-shrink: 0;
    width: clamp(52px, 9vw, 72px);
    height: auto;
    margin-left: 10px;
    transform-origin: 50% 90%;
    transition: transform 0.2s ease;
  }

  .section-videos__paw:hover {
    animation: section-videos-paw-sway 1.2s ease-in-out infinite;
  }

  @keyframes section-videos-paw-sway {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-8deg); }
    75% { transform: rotate(8deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-videos__paw:hover {
      animation: none;
    }
  }

  .btn--yt {
    width: fit-content;
    max-width: 100%;
    font-size: 22px;
    letter-spacing: 0.05em;
    padding: 0 24px;
    margin-top: 4px;
  }

  .btn--yt .btn__icon--play {
    display: block;
    width: auto;
    height: 36px;
    border: none;
    margin-left: -3px;
  }

  .section-videos__player {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #c8d9e6;
  }

  .section-videos__iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .section-videos {
      padding: 48px var(--section-inset-x) 44px;
    }

    .section-videos__header {
      flex-direction: column;
      gap: 16px;
    }

    .section-videos__title :global(.title-with-underline__decoration) {
      width: var(--underline-width, 11rem);
      max-width: 100%;
    }

    .section-videos__paw {
      width: clamp(52px, 14vw, 70px);
    }

    .btn--yt {
      width: fit-content;
      max-width: 100%;
      height: 56px;
      font-size: 15px;
      letter-spacing: 0.06em;
      padding: 0 20px;
      gap: 10px;
      margin-top: 0;
    }

    .btn--yt .btn__icon--play {
      height: 32px;
    }
  }

  @media (max-width: 640px) {
    .section-videos__paw {
      width: clamp(48px, 13vw, 58px);
    }

    .btn--yt {
      height: 44px;
      font-size: 11px;
      letter-spacing: 0.04em;
      padding: 0 14px;
      gap: 8px;
      border-radius: 22px;
    }

    .btn--yt .btn__icon--play {
      height: 28px;
    }
  }
</style>
