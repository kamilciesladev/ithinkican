---
import TitleWithUnderline from './TitleWithUnderline.astro';

const youtubeVideoId = 'dQw4w9WgXcQ';
const youtubeEmbedUrl = `https://www.youtube.com/embed/${youtubeVideoId}`;
const youtubeChannelUrl = 'https://www.youtube.com/';
---

<section id="spoty" class="section-videos">
  <div class="section-videos__header">
    <TitleWithUnderline
      variant="flourish"
      align="left"
      size="compact"
      underlineWidth={11}
      underlineThickness={1.35}
      class="section-videos__title"
    >
      Spot video
    </TitleWithUnderline>
    <a
      href={youtubeChannelUrl}
      class="btn btn--blue btn--yt"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        class="btn__icon btn__icon--play"
        src="/assets/icon-play.svg"
        alt=""
        aria-hidden="true"
      />
      OBEJRZYJ SPOT NA YOUTUBE
    </a>
  </div>

  <div class="section-videos__player">
    <iframe
      class="section-videos__iframe"
      src={youtubeEmbedUrl}
      title="Spot wideo"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
</section>

<style>
  .section-videos {
    background: #fff;
    padding: 54px var(--section-inset-x) 64px;
  }

  .section-videos__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 40px;
  }

  .section-videos__title {
    flex-shrink: 0;
  }

  .btn--yt {
    width: 507px;
    font-size: 24px;
    margin-top: 4px;
  }

  .btn--yt .btn__icon--play {
    display: block;
    width: auto;
    height: 36px;
    border: none;
  }

  .section-videos__player {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #c8d9e6;
  }

  .section-videos__iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  @media (max-width: 900px) {
    .section-videos {
      padding: 48px var(--section-inset-x) 44px;
    }
  }
</style>
