---
---

<html lang="pl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>On Da Radę</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700&family=Barlow:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>

<!-- ═══════════════════════════════════════════════════
     HEADER
════════════════════════════════════════════════════ -->
<header class="hdr">
  <div class="hdr__logo">
    <span class="logo-on">ON</span>
    <span class="logo-da">DA</span>
    <span class="logo-rade">RADĘ</span>
  </div>
  <nav class="hdr__nav">
    <a href="#kampanii">O kampanii</a>
    <a href="#przyklady">Dobre przykłady</a>
    <a href="#materialy">Materiały</a>
    <a href="#pobieranie">Do pobrania</a>
    <a href="#zrodla">Źródła</a>
    <a href="#kontakt">Kontakt</a>
  </nav>
  <div class="hdr__social">
    <span class="social-icon">f</span>
    <span class="social-icon">ig</span>
    <span class="social-icon">▶</span>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════ -->
<section class="hero" id="kampanii">
  <div class="hero__left">
    <h1 class="hero__title">ON<br/>DA<br/>RADĘ</h1>
    <p class="hero__sub">Świadomy wybór partnera<br/>to inwestycja w przyszłość<br/>Twoją i Twoich dzieci.</p>
    <div class="hero__buttons">
      <a href="#pobieranie" class="btn btn--outline">ZOBACZ ULOTKĘ</a>
      <a href="#spoty" class="btn btn--pink">▶ OBEJRZYJ SPOTY</a>
    </div>
  </div>
  <div class="hero__right">
    <div class="hero__illustration">
      <!-- placeholder for father+child illustration -->
      <div class="illus-placeholder">👨‍👦</div>
    </div>
    <div class="hero__badge">
      Dobry partner.<br/>Zaangażowany ojciec.<br/>Lepsze priorytety.
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     O CO CHODZI W KAMPANII?
════════════════════════════════════════════════════ -->
<section class="section section--pink">
  <div class="container">
    <h2 class="section__title">O co chodzi w kampanii?</h2>
    <div class="campaign-info">
      <div class="campaign-info__illus">
        <div class="illus-placeholder illus-placeholder--lg">👨‍👩‍👧</div>
      </div>
      <div class="campaign-info__text">
        <p class="highlight"><strong>Nie każda relacja jest dobra.<br/>Nie każdy partner będzie dobrym ojcem.</strong></p>
        <p>Kampania „On da radę" zachęca kobiety do świadomego wyboru partnerów, pokazując cechy mężczyzn, którzy budują zdrowe związki, angażując się w wychowanie dzieci i tworzą bezpieczne środowisko dla rodziny.</p>
        <p class="highlight--pink"><em>Naszym celem nie jest ocenianie ludzi, lecz promowanie dobrych wzorców.</em></p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     CZY ON DA RADĘ? (Checklist)
════════════════════════════════════════════════════ -->
<section class="section" id="przyklady">
  <div class="container">
    <h2 class="section__title">Czy on da radę?</h2>
    <div class="checklist-grid">
      <div class="checklist checklist--green">
        <h3 class="checklist__heading checklist__heading--green">DOBRZE ✓</h3>
        <ul>
          <li>bierze odpowiedzialność za swoje decyzje</li>
          <li>dotrzymuje obietnicy</li>
          <li>angażuje się w opiekę nad dzieckiem</li>
          <li>szanuje granice</li>
          <li>potrafi rozmawiać o emocjach</li>
          <li>wspiera partnerów</li>
          <li>rozwiązuje konflikty bez przemocy</li>
        </ul>
      </div>
      <div class="checklist checklist--red">
        <h3 class="checklist__heading checklist__heading--red">UWAŻAJ !</h3>
        <ul>
          <li>ciągle obwinia innych</li>
          <li>jest agresywny słownie</li>
          <li>ignoruje potrzeby dziecka</li>
          <li>manipuluje</li>
          <li>nie szanuje granic</li>
          <li>nadużywa alkoholu</li>
          <li>nie bierze odpowiedzialności za swoje działania</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     DOBRE PRZYKŁADY
════════════════════════════════════════════════════ -->
<section class="section section--lightgray">
  <div class="container">
    <h2 class="section__title">Dobre przykłady ojców z całego świata</h2>
    <div class="examples-grid">
      {[
        { name: "FRED ROGERS",     desc: "Pokazywał milionom jak empatia i troska są znaką siły." },
        { name: "BARACK OBAMA",    desc: "Wielokrotnie podkreślał rolę obecnego ojca w życiu dziecka." },
        { name: "DWAYNE JOHNSON",  desc: "Publicznie pokazuje zaangażowane ojcostwo i budowanie relacji z córkami." },
        { name: "LEBRON JAMES",    desc: "Aktywnie uczestniczy w życiu swoich dzieci i wspiera edukację młodzieży." },
      ].map(p => (
        <div class="example-card">
          <div class="example-card__avatar">👤</div>
          <h4 class="example-card__name">{p.name}</h4>
          <p class="example-card__desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     SPOTY WIDEO
════════════════════════════════════════════════════ -->
<section class="section" id="spoty">
  <div class="container">
    <div class="video-section">
      <div class="video-section__cta">
        <span class="play-circle">▶</span>
        <span>ZOBACZ 3 SPOTY<br/>KAMPANII NA YOUTUBE</span>
      </div>
      <div class="video-grid">
        {[
          { label: "SPOT 1", desc: "Osoba wybiera partnera na podstawie zachowania, nie deklaracji." },
          { label: "SPOT 2", desc: "Zaangażowany ojciec od pierwszych dni w życiu dziecka." },
          { label: "SPOT 3", desc: "Prawdziwa siła to odpowiedzialność." },
        ].map(v => (
          <div class="video-card">
            <div class="video-card__thumb">
              <span class="play-circle play-circle--sm">▶</span>
            </div>
            <p class="video-card__label">{v.label}</p>
            <p class="video-card__desc">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     SPOT RADIOWY + POBIERZ ULOTKĘ
════════════════════════════════════════════════════ -->
<section class="section section--split" id="pobieranie">
  <div class="container split-row">

    <!-- Radio mock -->
    <div class="radio-block">
      <h3 class="block-title">Spot radiowy</h3>
      <p>Posłuchaj spotu kampanii</p>
      <div class="audio-player">
        <span class="play-circle play-circle--sm">▶</span>
        <div class="audio-bar">
          <div class="audio-bar__fill"></div>
        </div>
        <span class="audio-time">0:00 / 0:30</span>
        <span class="audio-volume">🔊</span>
      </div>
    </div>

    <!-- PDF download mock -->
    <div class="pdf-block">
      <h3 class="block-title">Pobierz ulotkę kampanii</h3>
      <p>Praktyczny poradnik o świadomym wyborze partnera i dobrym ojcostwie.</p>
      <a href="#" class="btn btn--pink btn--full" onclick="return false;">↓ POBIERZ ULOTKĘ PDF</a>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     MOTYWUJĄCE MYŚLI
════════════════════════════════════════════════════ -->
<section class="section section--lightpink" id="materialy">
  <div class="container">
    <h2 class="section__title">Motywujące myśli</h2>
    <div class="quotes-grid">
      {[
        "Dziecko nie potrzebuje idealnego ojca. Potrzebuje obecnego ojca.",
        "Odpowiedzialność jest atrakcyjna.",
        "Dobry partner to ktoś, komu możesz ufać także wtedy, gdy jest trudno.",
        "Miłość to nie słowo. To codzienne działania.",
      ].map(q => (
        <div class="quote-card">
          <span class="quote-mark">&ldquo;</span>
          <p>{q}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     FAKTY I ŹRÓDŁA
════════════════════════════════════════════════════ -->
<section class="section" id="zrodla">
  <div class="container">
    <h2 class="section__title">Fakty i źródła</h2>
    <div class="sources-grid">
      <ul class="sources-list">
        <li>Raport OECD – Families and Parenting</li>
        <li>UNICEF – Fatherhood and Child Development</li>
        <li>GUS – Rodzina i gospodarstwo domowe</li>
        <li>Eurostat – Gender Equality</li>
        <li>WHO – Men and Health</li>
      </ul>
      <ul class="sources-list">
        <li>Niebieska Linia – Przemoc w rodzinie</li>
        <li>Fundacja Dajemy Dzieciom Siłę – Raporty</li>
        <li>Instytut Matki i Dziecka – Ojcostwo</li>
        <li>CBOS – Postawy wobec ról rodzinnych</li>
        <li>Raport "Tata na 100%" – Fundacja SHARE THE CARE</li>
      </ul>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     FOOTER
════════════════════════════════════════════════════ -->
<footer class="footer" id="kontakt">
  <div class="container footer__inner">
    <div class="footer__logo">
      <span class="logo-on">ON</span><span class="logo-da">DA</span><span class="logo-rade">RADĘ</span>
      <p>Świadomy wybór. Lepsze relacje. Lepsze ojcostwo.</p>
    </div>
    <nav class="footer__nav">
      <a href="#kampanii">O kampanii</a>
      <a href="#materialy">Materiały</a>
      <a href="#pobieranie">Do pobrania</a>
      <a href="#kontakt">Kontakt</a>
    </nav>
    <div class="footer__social">
      <span class="social-icon">f</span>
      <span class="social-icon">ig</span>
      <span class="social-icon">▶</span>
    </div>
  </div>
  <p class="footer__copy">© 2024 Kampania On Da Radę</p>
</footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --pink:       #d7316e;
    --blue:       #225ea1;
    --lightpink:  #fcebf0;
    --green:      #4caa50;
    --red:        #e03030;
    --text:       #1a1a1a;
    --gray:       #f5f5f5;
    --font-cond:  'Barlow Condensed', sans-serif;
    --font-body:  'Barlow', sans-serif;
  }

  body {
    font-family: var(--font-body);
    color: var(--text);
    background: #fff;
    font-size: 16px;
    line-height: 1.5;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

  /* ── Header ── */
  .hdr {
    display: flex; align-items: center; gap: 24px;
    padding: 16px 40px;
    background: #fff;
    border-bottom: 1px solid #eee;
    position: sticky; top: 0; z-index: 100;
  }
  .hdr__logo { font-family: var(--font-cond); font-weight: 700; font-size: 20px; display: flex; gap: 2px; align-items: baseline; }
  .logo-on   { color: var(--pink); }
  .logo-da   { color: var(--blue); font-size: 14px; }
  .logo-rade { color: var(--pink); }
  .hdr__nav  { display: flex; gap: 20px; margin-left: auto; }
  .hdr__nav a { font-family: var(--font-cond); font-weight: 700; font-size: 15px; text-decoration: none; color: var(--text); letter-spacing: .5px; }
  .hdr__nav a:hover { color: var(--pink); }
  .hdr__social { display: flex; gap: 8px; margin-left: 24px; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 14px 28px; border-radius: 40px;
    font-family: var(--font-cond); font-weight: 700; font-size: 18px; letter-spacing: 1px;
    text-decoration: none; cursor: pointer; border: none;
    transition: filter .2s;
  }
  .btn:hover { filter: brightness(1.1); }
  .btn--pink    { background: var(--pink); color: #fff; }
  .btn--blue    { background: var(--blue); color: #fff; }
  .btn--outline { background: transparent; color: var(--pink); border: 2px solid var(--pink); }
  .btn--full    { width: 100%; margin-top: 16px; }

  /* ── Social icons ── */
  .social-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--pink); color: #fff;
    font-size: 11px; font-weight: 700; cursor: pointer;
  }

  /* ── Hero ── */
  .hero {
    display: flex; align-items: center;
    min-height: 480px;
    background: linear-gradient(135deg, #fff5f8 0%, #e8f0fa 100%);
    padding: 60px 80px;
    gap: 40px;
    position: relative;
    overflow: hidden;
  }
  .hero__left  { flex: 1; }
  .hero__right { flex: 1; display: flex; justify-content: flex-end; align-items: center; gap: 24px; }
  .hero__title {
    font-family: var(--font-cond); font-weight: 700; font-size: 96px; line-height: .9;
    color: var(--pink); letter-spacing: 2px; margin-bottom: 24px;
  }
  .hero__sub   { font-size: 20px; margin-bottom: 32px; color: #333; line-height: 1.5; }
  .hero__buttons { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero__illustration { font-size: 180px; line-height: 1; }
  .hero__badge {
    background: rgba(255,255,255,.85); border-radius: 12px; padding: 16px;
    font-size: 14px; font-weight: 700; color: var(--blue); text-align: center;
    box-shadow: 0 2px 12px rgba(0,0,0,.1);
    max-width: 160px;
  }

  /* ── Sections ── */
  .section         { padding: 64px 0; }
  .section--pink   { background: var(--lightpink); }
  .section--lightpink { background: #fef4f7; }
  .section--lightgray { background: var(--gray); }
  .section--split  { background: #1a2a4a; color: #fff; }

  .section__title {
    font-family: var(--font-cond); font-weight: 700; font-size: 40px;
    text-align: center; margin-bottom: 40px; letter-spacing: 1px;
  }

  /* ── Campaign info ── */
  .campaign-info { display: flex; gap: 48px; align-items: center; }
  .campaign-info__illus { font-size: 120px; flex-shrink: 0; }
  .campaign-info__text  { flex: 1; }
  .campaign-info__text p { margin-bottom: 16px; font-size: 17px; }
  .highlight      { font-size: 20px; margin-bottom: 20px; }
  .highlight--pink { color: var(--pink); font-style: italic; }

  /* ── Checklist ── */
  .checklist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .checklist {
    border-radius: 16px; padding: 32px;
    box-shadow: 0 2px 16px rgba(0,0,0,.08);
    background: #fff;
  }
  .checklist__heading {
    font-family: var(--font-cond); font-size: 28px; font-weight: 700;
    margin-bottom: 20px; padding: 8px 16px; border-radius: 8px; display: inline-block;
  }
  .checklist__heading--green { background: var(--green); color: #fff; }
  .checklist__heading--red   { background: var(--red);   color: #fff; }
  .checklist ul { list-style: none; }
  .checklist--green li::before { content: "✓ "; color: var(--green); font-weight: 700; }
  .checklist--red   li::before { content: "✗ "; color: var(--red);   font-weight: 700; }
  .checklist li { padding: 8px 0; font-size: 16px; border-bottom: 1px solid #f0f0f0; }
  .checklist li:last-child { border-bottom: none; }

  /* ── Examples ── */
  .examples-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .example-card { background: #fff; border-radius: 16px; padding: 28px 20px; text-align: center; box-shadow: 0 2px 12px rgba(0,0,0,.07); }
  .example-card__avatar { font-size: 64px; margin-bottom: 12px; }
  .example-card__name   { font-family: var(--font-cond); font-weight: 700; font-size: 18px; color: var(--blue); margin-bottom: 10px; }
  .example-card__desc   { font-size: 14px; color: #555; line-height: 1.5; }

  /* ── Video ── */
  .video-section { display: flex; gap: 40px; align-items: flex-start; }
  .video-section__cta {
    flex-shrink: 0; width: 200px;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
    font-family: var(--font-cond); font-weight: 700; font-size: 18px;
    text-align: center; color: var(--pink);
  }
  .video-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; flex: 1; }
  .video-card { text-align: center; }
  .video-card__thumb {
    width: 100%; aspect-ratio: 16/9; background: #111;
    border-radius: 10px; display: flex; align-items: center; justify-content: center;
    margin-bottom: 10px; cursor: pointer;
  }
  .video-card__label { font-family: var(--font-cond); font-weight: 700; font-size: 14px; color: var(--blue); }
  .video-card__desc  { font-size: 13px; color: #555; margin-top: 4px; }

  .play-circle {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--pink); color: #fff; font-size: 20px; cursor: pointer;
    flex-shrink: 0;
  }
  .play-circle--sm { width: 40px; height: 40px; font-size: 14px; }

  /* ── Split section (radio + pdf) ── */
  .split-row    { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
  .block-title  { font-family: var(--font-cond); font-weight: 700; font-size: 28px; margin-bottom: 12px; color: #fff; }
  .radio-block p, .pdf-block p { color: #ccd; margin-bottom: 16px; }

  .audio-player {
    display: flex; align-items: center; gap: 12px;
    background: rgba(255,255,255,.1); border-radius: 40px; padding: 12px 20px; margin-top: 16px;
  }
  .audio-bar       { flex: 1; height: 4px; background: rgba(255,255,255,.3); border-radius: 4px; }
  .audio-bar__fill { width: 0%; height: 100%; background: var(--pink); border-radius: 4px; }
  .audio-time      { color: #ccd; font-size: 13px; white-space: nowrap; }
  .audio-volume    { font-size: 18px; cursor: pointer; }

  .pdf-block {
    background: var(--pink); border-radius: 16px; padding: 32px;
  }

  /* ── Quotes ── */
  .quotes-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .quote-card  {
    background: #fff; border-radius: 16px; padding: 28px 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,.06); text-align: center;
    font-style: italic; font-size: 15px; color: #333; line-height: 1.6;
  }
  .quote-mark  { display: block; font-size: 48px; color: var(--pink); line-height: 1; margin-bottom: 8px; font-style: normal; }

  /* ── Sources ── */
  .sources-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .sources-list { list-style: none; }
  .sources-list li {
    padding: 10px 0; border-bottom: 1px solid #eee;
    font-size: 15px; color: var(--blue); cursor: pointer;
  }
  .sources-list li:hover { text-decoration: underline; }
  .sources-list li::before { content: "→ "; color: var(--pink); }

  /* ── Footer ── */
  .footer { background: #111; color: #ccc; padding: 48px 0 24px; }
  .footer__inner { display: flex; align-items: flex-start; gap: 48px; }
  .footer__logo  { flex: 1; }
  .footer__logo .logo-on, .footer__logo .logo-rade { color: var(--pink); font-family: var(--font-cond); font-weight: 700; font-size: 24px; }
  .footer__logo .logo-da { color: #fff; font-family: var(--font-cond); font-weight: 700; font-size: 18px; }
  .footer__logo p { color: #aaa; margin-top: 8px; font-size: 13px; }
  .footer__nav { display: flex; flex-direction: column; gap: 10px; }
  .footer__nav a { color: #bbb; text-decoration: none; font-size: 14px; }
  .footer__nav a:hover { color: #fff; }
  .footer__social { display: flex; gap: 8px; align-items: flex-start; }
  .footer__copy { text-align: center; padding: 24px 0 0; color: #666; font-size: 13px; }

  /* ── Illus placeholder ── */
  .illus-placeholder     { font-size: 64px; text-align: center; }
  .illus-placeholder--lg { font-size: 100px; }
</style>
